# uawso_daily operational configuration - names and safe example values only.
# NO CREDENTIALS BELONG IN THIS FILE. Database credentials come exclusively
# from 05_IMPLEMENTATION/config/.env (PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD),
# which is git-ignored and NTFS-restricted - see that file's own .env.example.
#
# To use: copy any of the lines below into your real process environment
# (or into config/.env alongside the DB credentials) and adjust the value.
# Every variable here has a safe built-in default - none are required.

# IANA timezone name for all daily-boundary and report-window calculations.
UAWSO_TIMEZONE=Asia/Colombo

UAWSO_PROJECT_CODE=UAWSO
UAWSO_ASSIGNED_USER=utharsika
UAWSO_ASSIGNED_USER_TEAM=ph_priors

# Fixed project start date - the report_start_date for every run.
UAWSO_REPORT_START_DATE=2025-01-01

# How many days behind report_end_date the live source is allowed to be
# before a run is refused with SOURCE_NOT_READY. 0 = source must reach
# exactly report_end_date (yesterday, Colombo time).
UAWSO_FRESHNESS_TOLERANCE_DAYS=0

# Bounded retry policy for transient DB connection failures only (never for
# validation failures - see uawso_daily/README.md "Retry policy").
UAWSO_DB_RETRY_COUNT=3
UAWSO_DB_RETRY_BASE_DELAY_SECONDS=2

# Output/evidence locations - defaults to the standard project folders.
# UAWSO_OUTPUT_DIR=09_OUTPUTS
# UAWSO_EVIDENCE_DIR=07_EVIDENCE

# Set to false to force every run down the --no-publish path regardless of
# CLI flags - an operational kill-switch for ph_task writes without editing code.
UAWSO_PUBLICATION_ENABLED=true

# Set to true to make --dry-run the default behavior even when no flag is passed.
UAWSO_DRY_RUN_DEFAULT=false

UAWSO_LOG_RETENTION_DAYS=30
